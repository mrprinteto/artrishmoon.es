---
import Container from './Container.astro';
import Sparkles from './Sparkles.astro';
---

<section class="relative pt-36 pb-20 md:pt-44 md:pb-28 overflow-hidden">
  <!-- Decorative blobs -->
  <div
    class="absolute -top-24 -right-24 w-72 h-72 rounded-full blur-3xl opacity-40 pointer-events-none"
    style="background-color: var(--accent-soft);"
  >
  </div>
  <div
    class="absolute -bottom-16 -left-16 w-64 h-64 rounded-full blur-3xl opacity-30 pointer-events-none"
    style="background-color: var(--surface-hover);"
  >
  </div>

  <Sparkles />

  <Container class="relative">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="animate-on-scroll">
        <span class="font-sans text-sm mb-1 block" style="color: var(--text-muted);">Bienvenida</span>

        <h1 class="section-heading mb-5 !text-4xl md:!text-5xl lg:!text-6xl">
          Carteles y manualidades con <span class="signature">alma</span>
        </h1>

        <p class="text-lg mb-8 max-w-lg" style="color: var(--text-muted);">
          Soy Patricia, y bajo <strong style="color: var(--text);">ArtrishMoon</strong> creo carteles
          de madera para cumpleaños, decoración infantil y regalos personalizados. Cada pieza se
          diseña y talla pensando en quien la va a recibir.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="#contacto" class="btn-primary">
            Pide tu encargo
            <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
          </a>
          <a href="#productos" class="btn-secondary"> Ver productos </a>
        </div>
      </div>

      <div class="animate-on-scroll relative" data-delay="1">
        <div
          class="washi-tape left"
          style="top: -10px; left: calc(50% - 130px);"
        >
        </div>
        <div
          class="card p-3 rotate-2 max-w-md mx-auto relative"
          style="background-color: var(--surface-card);"
        >
          <img
            src="/productos/product-1.jpg"
            alt="Cartel de madera personalizado de ArtrishMoon"
            class="rounded-[var(--radius-sm)] w-full h-auto"
            width="640"
            height="480"
          />
          <span
            class="absolute -bottom-5 -right-5 flex flex-col items-center justify-center w-24 h-24 rounded-full text-center text-xs font-semibold leading-tight"
            style="background-color: var(--tangerine, #f3997c); color: #fff; transform: rotate(-8deg); box-shadow: 0 10px 22px rgba(210,121,92,0.35); animation: seal-pop 0.6s ease-out 0.4s both;"
          >
            Hecho<br />a mano
          </span>
        </div>
      </div>
    </div>
  </Container>
</section>
