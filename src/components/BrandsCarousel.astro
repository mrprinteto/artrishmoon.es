---
import Container from './Container.astro';
import Section from './Section.astro';
import SectionTitle from './SectionTitle.astro';
import Sparkles from './Sparkles.astro';

// BrandsCarousel — auto-scrolling marquee of partner/collaborator brand logos
const brands = [
  { name: 'Elegoo', src: 'https://assets.mrprinteto.com/brands/elegoo/elegoo-logo.avif' },
  { name: 'Creality', src: 'https://assets.mrprinteto.com/brands/creality/creality-logo.png' },
  { name: 'Snapmaker', src: 'https://assets.mrprinteto.com/brands/snapmaker/snapmaker-logo.webp' },
  { name: 'Sakata 3D', src: 'https://assets.mrprinteto.com/brands/sakata3d/logo.jpg' },
  {
    name: 'Creality Falcon',
    src: 'https://assets.mrprinteto.com/brands/creality-falcon/creality-falcon-logo.webp',
  },
  { name: 'LaserPecker', src: 'https://assets.mrprinteto.com/brands/laserpecker/laserpecker-logo.webp' },
  { name: 'WeCreat', src: 'https://assets.mrprinteto.com/brands/wecreat/wecreat-logo.avif' },
  { name: 'Anycubic', src: 'https://assets.mrprinteto.com/brands/anycubic/anycubic-logo.webp' },
  { name: 'Bambu Lab', src: 'https://assets.mrprinteto.com/brands/bambulab/bambulab-logo.webp' },
  { name: 'FlashForge', src: 'https://assets.mrprinteto.com/brands/flashforge/flashforge-logo.avif' },
];

// Duplicate list for a seamless infinite loop
const track = [...brands, ...brands];
---

<Section id="marcas">
  <Sparkles />
  <Container>
    <SectionTitle
      title="Gracias por confiar en mí"
      subtitle=""
    />
  </Container>

  <div class="marquee-wrapper animate-on-scroll">
    <div class="marquee-track">
      {
        track.map((brand) => (
          <div class="marquee-item" title={brand.name}>
            <img src={brand.src} alt={brand.name} loading="lazy" />
          </div>
        ))
      }
    </div>
  </div>
</Section>

<style>
  .marquee-wrapper {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    animation: brand-marquee 32s linear infinite;
  }

  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 2.5rem;
  }

  .marquee-item img {
    height: 100%;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(1) opacity(0.6);
    transition: filter 0.25s ease;
  }

  .marquee-item img:hover {
    filter: grayscale(0) opacity(1);
  }

  @keyframes brand-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
