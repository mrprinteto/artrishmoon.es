---
import Container from './Container.astro';
import Section from './Section.astro';
import SectionTitle from './SectionTitle.astro';
import Sparkles from './Sparkles.astro';

// BrandsCarousel — auto-scrolling marquee of partner/collaborator brand logos
const brands = [
  { name: 'Natalicio Gabriel', src: '/productos/gabriel.jpg' },
  { name: 'Natalicio Teresa', src: '/productos/teresa.jpg' },
  { name: 'Natalicio Adrian', src: '/productos/adrian_nata.jpg' },
  { name: 'Natalicio Ana Claudia', src: '/productos/ana_claudia.jpg' },
  { name: 'Natalicio Julia', src: '/productos/product-1.jpg' },
  { name: 'Natalicio Oliver', src: '/productos/oliver_nata.jpg' },
  { name: 'Natalicio Martín', src: '/productos/martin.png' },
  { name: 'Natalicio Pedro', src: '/productos/pedro.jpg' },
  { name: 'Cartel Adrian', src: '/productos/adrian.jpg' },
  { name: 'Cartel Ana Claudia', src: '/productos/ratas.jpg' },
  { name: 'Cartel Oliver', src: '/productos/oliver_cartel.jpg' },
  { name: 'Casita Ratoncito Perez', src: '/productos/raton_perez.jpg' },
];

// Duplicate list for a seamless infinite loop
const track = [...brands, ...brands];
---

<Section id="marcas">
  <Sparkles />
  <Container>
    <SectionTitle
      title="Gracias por confiar en mí:"
      subtitle=""
    />
  </Container>

  <div class="marquee-wrapper animate-on-scroll">
    <div class="marquee-track">
      {
        track.map((brand) => (
          <div class="marquee-item" title={brand.name}>
            <img src={brand.src} alt={brand.name} loading="lazy" />
          </div>
        ))
      }
    </div>
  </div>
</Section>

<style>
  .marquee-wrapper {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    animation: brand-marquee 32s linear infinite;
  }

  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 14rem;
  }

  .marquee-item img {
    height: 100%;
    width: auto;
    max-width: 420px;
    min-width: 240px;
    object-fit: contain;
    filter: grayscale(1) opacity(0.6);
    transition: filter 0.25s ease;
  }

  .marquee-item img:hover {
    filter: grayscale(0) opacity(1);
  }

  @keyframes brand-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
