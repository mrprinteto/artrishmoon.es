---
import { getCollection } from 'astro:content';
import Container from './Container.astro';
import Section from './Section.astro';
import ProductCard from './ProductCard.astro';
import SectionTitle from './SectionTitle.astro';
import SectionDivider from './SectionDivider.astro';

const productos = (await getCollection('productos')).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured)
);

const rotations = ['-rotate-1', 'rotate-1', '-rotate-1', 'rotate-2'];
---

<Section id="productos" style="background-color: var(--surface);">
  <Container>
    <SectionTitle
      title="Productos"
      subtitle="Estos son algunos de los ejemplos que puedo crear para ti:"
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        productos.map((producto, i) => (
          <div class:list={['animate-on-scroll', rotations[i % rotations.length]]} data-delay={String((i % 3) + 1)}>
            <ProductCard producto={producto} />
          </div>
        ))
      }
    </div>
  </Container>
</Section>
<SectionDivider color="var(--bg)" flip />
