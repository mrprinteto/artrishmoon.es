---
/**
 * Sparkles.astro — a few floating decorative stars/dots for a "magic" feel.
 * Place inside a `position: relative` container.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const items = [
  { icon: 'fa-solid fa-star', top: '8%', left: '4%', size: '1rem', delay: '0s', dur: '6s', rot: '-10deg', color: 'var(--accent)' },
  { icon: 'fa-solid fa-sparkle', top: '18%', left: '92%', size: '1.4rem', delay: '0.6s', dur: '7s', rot: '12deg', color: 'var(--tangerine, #f3997c)' },
  { icon: 'fa-solid fa-star', top: '78%', left: '6%', size: '0.85rem', delay: '1.1s', dur: '6.5s', rot: '18deg', color: 'var(--tangerine, #f3997c)' },
  { icon: 'fa-solid fa-sparkle', top: '85%', left: '88%', size: '1.1rem', delay: '0.3s', dur: '7.5s', rot: '-14deg', color: 'var(--accent)' },
  { icon: 'fa-solid fa-star', top: '4%', left: '45%', size: '0.7rem', delay: '0.9s', dur: '5.5s', rot: '8deg', color: 'var(--accent)' },
  { icon: 'fa-solid fa-sparkle', top: '32%', left: '20%', size: '0.8rem', delay: '1.6s', dur: '6.8s', rot: '-6deg', color: 'var(--tangerine, #f3997c)' },
  { icon: 'fa-solid fa-star', top: '55%', left: '95%', size: '0.75rem', delay: '0.2s', dur: '6.2s', rot: '15deg', color: 'var(--accent)' },
  { icon: 'fa-solid fa-sparkle', top: '92%', left: '40%', size: '1rem', delay: '1.3s', dur: '7.2s', rot: '-10deg', color: 'var(--tangerine, #f3997c)' },
  { icon: 'fa-solid fa-star', top: '48%', left: '2%', size: '0.9rem', delay: '0.5s', dur: '6.4s', rot: '-18deg', color: 'var(--tangerine, #f3997c)' },
  { icon: 'fa-solid fa-sparkle', top: '65%', left: '55%', size: '0.65rem', delay: '2s', dur: '5.8s', rot: '10deg', color: 'var(--accent)' },
  { icon: 'fa-solid fa-star', top: '12%', left: '70%', size: '0.6rem', delay: '1.4s', dur: '6.6s', rot: '-8deg', color: 'var(--accent)' },
  { icon: 'fa-solid fa-sparkle', top: '38%', left: '80%', size: '0.9rem', delay: '0.8s', dur: '7.1s', rot: '16deg', color: 'var(--tangerine, #f3997c)' },
];
---

<div class:list={['absolute inset-0 pointer-events-none', className]} aria-hidden="true">
  {
    items.map((item) => (
      <span class="sparkle-dot" style={`top:${item.top}; left:${item.left};`}>
        <i
          class={`sparkle ${item.icon}`}
          style={`font-size:${item.size}; color:${item.color}; animation-delay:${item.delay}; animation-duration:${item.dur}, 3.5s; --float-rot:${item.rot};`}
        />
      </span>
    ))
  }
</div>

<script>
  // Stars gently dodge the mouse pointer when it gets close.
  const wraps = Array.from(document.querySelectorAll<HTMLElement>('.sparkle-dot'));

  if (wraps.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const RADIUS = 90;
    const MAX_PUSH = 55;
    let mouseX = -9999;
    let mouseY = -9999;
    let ticking = false;

    const updateSparkles = () => {
      for (const el of wraps) {
        const rect = el.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = cx - mouseX;
        const dy = cy - mouseY;
        const dist = Math.hypot(dx, dy);

        if (dist < RADIUS) {
          const angle = Math.atan2(dy, dx);
          const strength = (1 - dist / RADIUS) * MAX_PUSH;
          const px = Math.cos(angle) * strength;
          const py = Math.sin(angle) * strength;
          el.style.transform = `translate(${px}px, ${py}px)`;
        } else {
          el.style.transform = '';
        }
      }
      ticking = false;
    };

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(updateSparkles);
      }
    });

    window.addEventListener('mouseleave', () => {
      mouseX = -9999;
      mouseY = -9999;
      requestAnimationFrame(updateSparkles);
    });
  }
</script>
